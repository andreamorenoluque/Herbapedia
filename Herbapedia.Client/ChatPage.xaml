<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Herbapedia.Client.ChatPage">
    <StackLayout Padding="10">
        <CollectionView x:Name="cv_Mensajes" SelectionMode="Single" SelectionChanged="cv_Mensajes_SelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="5">
                        <StackLayout>
                            <Label Text="{Binding UserName}" 
                                   FontAttributes="Bold"/>
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

      
    </StackLayout>
</ContentPage>