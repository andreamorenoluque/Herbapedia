<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Herbapedia.Client.PlantViewPage"
             Title="PlantViewPage"
              xmlns:res="clr-namespace:Herbapedia.Client.Resources">
    <ScrollView>
        <VerticalStackLayout Padding="20">
           
   
            
            
            <!-- Descripción de la planta -->
            <Label Text="Descripción"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,20,0,0" />
            <Label Text="{Binding Plant.PlantDescription}" FontSize="16" TextColor="Black"
                   x:Name="DescriptionPlant"
                   Margin="0,10,0,0" 
                   />

            <!-- Consejos de cuidado -->
            <Label Text="Consejos"
                     FontSize="20"
                     FontAttributes="Bold"
                     Margin="0,20,0,0" />
            <Label Text="{Binding Plant.PlantTips}" FontSize="16" TextColor="Black"
                   x:Name="TipsPlant"
                   Margin="0,10,0,0" />

            <!--Elegir tipo de planta-->
            <Label Text="Tipo de planta"
                     FontSize="20"
                     FontAttributes="Bold"
                     Margin="0,20,0,0" />

            <Label Text="{Binding PlantType.PlantTypeName}" FontSize="18" TextColor="Black"
                   x:Name="PlantTypeName"/>


            <!-- Apartado de comentarios -->
            <Label Text="Comentarios"
                    FontSize="20"
                    FontAttributes="Bold"
                    Margin="0,20,0,0" />

            <Editor x:Name="commentEntry" AutoSize="TextChanges" Placeholder="Escribe tu comentario aquí..." ></Editor>


            <Button Text="Enviar comentario"
                       Clicked="OnCommentClicked"
                       BackgroundColor="Green"
                       TextColor="White"
                       Margin="0,0,0,0" 
                       IsEnabled="{Binding IsUserAuthenticated}"
                       HorizontalOptions="End"/>        

            <CollectionView x:Name="cv_Comments">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="Gray" StrokeThickness="1" Padding="10" Margin="5">
                            <VerticalStackLayout>
                                <Label Text="{Binding CommentCreator.UserName}" 
                                        FontSize="14" 
                                        FontAttributes="Bold" 
                                        TextColor="DarkBlue"/>
                                                        <Label Text="{Binding CommentContent}" 
                                        FontSize="16"/>
                                                        <Label Text="{Binding CommentDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}" 
                                        FontSize="12" 
                                        TextColor="Gray"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>